# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Supabase Service Role（仅后端使用，绝不能暴露给前端；用于文献爬虫 upsert / AI 摘要缓存写入）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DeepSeek (OpenAI 兼容)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAlex（可选，填邮箱进入 polite pool 享受更高限速）
OPENALEX_MAILTO=

# Coze 工作流（代码小工坊）
COZE_API_KEY=your-coze-api-key
COZE_CODE_WORKFLOW_ID=your-coze-code-workflow-id

# 文献爬虫触发密钥（/api/papers/crawl 需要 Bearer 该值才能调用）
CRAWL_SECRET=change-me-to-a-long-random-string
